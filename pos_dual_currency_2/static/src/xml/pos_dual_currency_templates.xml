<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_dual_currency_2.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('after-total')]" position="inside">
            <t t-if="props.data.dual_currency_enabled">
                <div class="dual-currency-line" style="display: flex; justify-content: space-between;">
                    <span class="label">≈ <t t-esc="props.data.dual_currency_symbol"/></span>
                    <span class="value" t-esc="props.data.dual_currency_total"/>
                </div>
            </t>
        </xpath>
    </t>
</templates>
