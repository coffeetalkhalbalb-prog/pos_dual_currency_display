<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_dual_currency_2.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//span[hasclass('label-total')]/.." position="before">
            <hr />
        </xpath>
        
        <xpath expr="//span[hasclass('label-total')]/.." position="after">
            <t t-if="props.order.dual_currency_data.dual_currency_enabled">
            <div class="d-flex flex-column">
                <div class="fw-bolder">
                    <span/>
                    <span t-esc="props.order.dual_currency_data.dual_currency_total" class="pos-receipt-right-align font-monospace"/>
                </div>
                <div>
                    <span>Rate</span>
                    <span t-esc="props.order.dual_currency_data.dual_currency_rate" class="pos-receipt-right-align font-monospace"/>
                </div>
            </div>
            </t>
        </xpath>
       <xpath expr="//div[hasclass('pos-receipt-order-data') and contains(., 'Powered by')]" position="replace">
            <div class="footer-spacer mb-3"/>
        </xpath>
    </t>
</templates>
