<templates id="template" xml:space="preserve">
    <t t-name="pos_dual_currency.OrderSummary" t-inherit="point_of_sale.OrderSummary" t-inherit-mode="extension">
        <xpath expr="//OrderDisplay" position="after">
            <t t-if="pos.isDualCurrencyEnabled()">
                <div class="dual-currency-display" style="width: 100%;">
                    <div class="dual-currency-total d-flex gap-1 p-2 fw-bolder lh-sm" style="display: flex; justify-content: space-between;">
                        <div />
                        <div>
                            <span class="total"><t t-esc="pos.dualCurrencyAmount"/></span>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </t>
    <t t-name="pos_dual_currency.PayButton" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension">
        <xpath expr="//button[contains(@class, 'pay-button')]" position="inside">
            <t t-if="pos.isDualCurrencyEnabled()">
                <br/>
                <small><t t-esc="pos.dualCurrencyAmount"/></small>
            </t>
        </xpath>
    </t>
</templates>
